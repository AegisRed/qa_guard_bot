TELEGRAM_BOT_TOKEN=1234567890:replace_me
GEMINI_API_KEY=replace_me
GEMINI_MODEL=gemini-3.1-flash-lite-preview

CHECK_INTERVAL_MINUTES=30
NOTIFY_ONLY_ON_CHANGES=true
SCHEDULER_ENABLED=true
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=25000
POST_LOAD_WAIT_MS=1500
LLM_MAX_PAGES_PER_RUN=3
LLM_FAIL_CONFIDENCE=0.82
TELEGRAM_ALLOWED_USER_IDS=
NOTIFY_CHAT_IDS=
REPORTS_DIR=reports
DB_PATH=qa_guard_bot.sqlite3

# Optional bootstrap list. If DB is empty on first run, these sites will be imported once.
SITES_JSON=[{"name":"Main site","url":"https://example.com","required_texts":["Example Domain"],"required_selectors":["body","h1"],"soft_expectations":"The page should look like a legitimate landing page with readable content and no broken or obviously missing layout.","max_console_errors":0,"max_page_errors":0,"max_request_failures":0,"min_visible_text_chars":80,"llm_enabled":true,"screenshot":true,"crawl_enabled":true,"crawl_max_pages":5,"include_subdomains":false,"ignored_failure_domains":["google-analytics.com","googletagmanager.com","doubleclick.net"]}]
